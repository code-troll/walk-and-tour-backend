{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TourAggregate",
  "description": "Superset schema for all tour data in this repo: catalog fields, locale availability, optional CTA targets, localized detail content, shared itinerary data, and resolved page data.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "slug",
    "rating",
    "reviews",
    "price",
    "tags",
    "heroImageSrc",
    "galleryImageSrcs",
    "localeAvailability"
  ],
  "properties": {
    "id": {
      "type": "string",
      "enum": [
        "copenhagenFreeTour",
        "rosenborgCastleTour",
        "malmoExcursion",
        "amalienborgPalace",
        "christiansborgPalace",
        "copenhagenEssentials",
        "jewishQuarter",
        "tivoliGardensEntry",
        "boatTour",
        "royalDeerParkBikeTour",
        "harborArchitecture",
        "rosenborgCastleCanalCruise",
        "frederiksborgAndKronborgCastle",
        "foodTours",
        "roskilde",
        "nordhavnArchitecture",
        "christmasTour",
        "panorama",
        "shoreExcursion",
        "copenhagenCityToCoast"
      ]
    },
    "slug": {
      "type": "string",
      "enum": [
        "copenhagen-historic-center-free-tour",
        "rosenborg-castle",
        "excursion-to-malmo-sweden",
        "amalienborg-palace",
        "christiansborg-palace",
        "copenhagen-essentials",
        "jewish-quarter-and-danish-jewish-museum",
        "copenhagen-walking-tour-tivoli-gardens-entry",
        "boat-tour-gateway",
        "bike-tour-deer-park",
        "copenhagen-harbor-architecture",
        "rosenborg-castle-and-canal-cruise",
        "frederiksborg-and-kronborg-castle",
        "copenhagen-food-tour",
        "roskilde-old-viking-city",
        "nordhavn-architecture",
        "private-ultimate-christmas-tivoli-hygge",
        "copenhagen-panorama-private-shore-to-city-experience",
        "copenhagen-walking-shore-excursion",
        "copenhagen-city-to-coast-black-diamond-canal-cruise-reffen"
      ]
    },
    "rating": {
      "type": "string",
      "description": "Stored as string in the repo, not number."
    },
    "reviews": {
      "type": "string",
      "description": "Stored as string, often with thousands separators."
    },
    "price": {
      "type": "string",
      "description": "Stored as string. UI appends 'kr'."
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "architecture",
          "bike",
          "boat",
          "cruise",
          "dayTrip",
          "essential",
          "freeTour",
          "groupTour",
          "history",
          "privateTour",
          "royalPalaces"
        ]
      }
    },
    "heroImageSrc": {
      "type": "string"
    },
    "galleryImageSrcs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "localeAvailability": {
      "$ref": "#/$defs/TourLocaleAvailability"
    },
    "translations": {
      "type": "object",
      "description": "Localized tourDetail.items payload by locale.",
      "additionalProperties": false,
      "properties": {
        "en": {
          "$ref": "#/$defs/LocalizedTourContent"
        },
        "es": {
          "$ref": "#/$defs/LocalizedTourContent"
        },
        "it": {
          "$ref": "#/$defs/LocalizedTourContent"
        }
      }
    }
  },
  "$defs": {
    "AppLocale": {
      "type": "string",
      "enum": [
        "en",
        "es",
        "it"
      ]
    },
    "TourLocaleAvailabilityEntry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bookingReferenceId": {
          "type": "string"
        }
      }
    },
    "TourLocaleAvailability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "en": {
          "$ref": "#/$defs/TourLocaleAvailabilityEntry"
        },
        "es": {
          "$ref": "#/$defs/TourLocaleAvailabilityEntry"
        },
        "it": {
          "$ref": "#/$defs/TourLocaleAvailabilityEntry"
        }
      }
    },
    "InternalPage": {
      "type": "string",
      "enum": [
        "/",
        "/tours",
        "/book-tour",
        "/about-us",
        "/companies",
        "/work-with-us",
        "/post",
        "/contact",
        "/privacy-policy",
        "/terms-of-use"
      ]
    },
    "HomeSectionId": {
      "type": "string",
      "enum": [
        "home",
        "about",
        "companies",
        "blog",
        "contact",
        "private"
      ]
    },
    "InternalTarget": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "page"
          ],
          "properties": {
            "kind": {
              "const": "page"
            },
            "page": {
              "$ref": "#/$defs/InternalPage"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "section"
          ],
          "properties": {
            "kind": {
              "const": "homeSection"
            },
            "section": {
              "$ref": "#/$defs/HomeSectionId"
            }
          }
        }
      ]
    },
    "LocalizedFacts": {
      "type": "object",
      "description": "Current raw keys in messages are below, but resolver accepts extra string keys.",
      "properties": {
        "meetingPoint": {
          "type": "string"
        },
        "endPoint": {
          "type": "string"
        },
        "cancellationType": {
          "type": "string"
        },
        "typeTour": {
          "type": "string"
        },
        "languages": {
          "type": "string"
        }
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "ResolvedFacts": {
      "type": "object",
      "description": "Resolved facts include raw facts plus computed singular `language`.",
      "properties": {
        "meetingPoint": {
          "type": "string"
        },
        "endPoint": {
          "type": "string"
        },
        "cancellationType": {
          "type": "string"
        },
        "typeTour": {
          "type": "string"
        },
        "languages": {
          "type": "string"
        },
        "language": {
          "type": "string"
        }
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "LocalizedItineraryStopCopy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "CommuteMode": {
      "type": "string",
      "enum": [
        "walk",
        "bike",
        "bus",
        "train",
        "metro",
        "tram",
        "ferry",
        "privateTransport",
        "boat",
        "other"
      ]
    },
    "ItineraryCoordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lat",
        "lng"
      ],
      "properties": {
        "lat": {
          "type": "number"
        },
        "lng": {
          "type": "number"
        }
      }
    },
    "ItineraryConnection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "durationMinutes": {
          "type": "number"
        },
        "mode": {
          "$ref": "#/$defs/CommuteMode"
        }
      }
    },
    "SharedItineraryStop": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "durationMinutes": {
          "type": "number"
        },
        "coordinates": {
          "$ref": "#/$defs/ItineraryCoordinates"
        },
        "nextConnection": {
          "$ref": "#/$defs/ItineraryConnection"
        }
      }
    },
    "SharedTourItinerary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stops"
      ],
      "properties": {
        "stops": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SharedItineraryStop"
          }
        }
      }
    },
    "ResolvedItineraryStop": {
      "allOf": [
        {
          "$ref": "#/$defs/SharedItineraryStop"
        },
        {
          "$ref": "#/$defs/LocalizedItineraryStopCopy"
        }
      ]
    },
    "ResolvedTourItinerary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stops"
      ],
      "properties": {
        "stops": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ResolvedItineraryStop"
          }
        }
      }
    },
    "LocalizedTourContent": {
      "type": "object",
      "description": "Raw per-locale entry from messages.<locale>.json under tourDetail.items.<tourId>.",
      "additionalProperties": false,
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "imageAlt": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "location": {
          "type": "string"
        },
        "aboutTourDescription": {
          "type": "string"
        },
        "description": {
          "type": "string",
          "description": "Legacy fallback key supported by resolver, not currently present in tour message data."
        },
        "highlights": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "itineraryDescription": {
          "type": "string"
        },
        "itineraryStops": {
          "type": "object",
          "description": "Optional localized copy map keyed by shared stop id.",
          "additionalProperties": {
            "$ref": "#/$defs/LocalizedItineraryStopCopy"
          }
        },
        "included": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notIncluded": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "facts": {
          "$ref": "#/$defs/LocalizedFacts"
        },
        "customerSupportDescription": {
          "type": "string",
          "description": "Supported by resolver, currently usually inherited from defaults."
        }
      }
    },
    "ResolvedDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "tag",
        "duration",
        "location"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "location": {
          "type": "string"
        }
      }
    },
    "ResolvedContent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "aboutTourDescription",
        "highlights",
        "itinerary",
        "itineraryDescription",
        "includedItems",
        "notIncludedItems",
        "customerSupportDescription",
        "facts"
      ],
      "properties": {
        "aboutTourDescription": {
          "type": "string"
        },
        "highlights": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "itinerary": {
          "oneOf": [
            {
              "$ref": "#/$defs/ResolvedTourItinerary"
            },
            {
              "type": "null"
            }
          ]
        },
        "itineraryDescription": {
          "type": "string"
        },
        "includedItems": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notIncludedItems": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "customerSupportDescription": {
          "type": "string"
        },
        "facts": {
          "$ref": "#/$defs/ResolvedFacts"
        }
      }
    },
    "AvailableLanguage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "locale",
        "label"
      ],
      "properties": {
        "locale": {
          "$ref": "#/$defs/AppLocale"
        },
        "label": {
          "type": "string"
        }
      }
    }
  }
}
